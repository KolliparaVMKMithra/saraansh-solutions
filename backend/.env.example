# Database Configuration (choose one)

# For Azure SQL Database:
# DB_CONNECTION_STRING=Driver={ODBC Driver 17 for SQL Server};Server=YOUR_SERVER.database.windows.net;Database=applicants_db;UID=your_user@your_server;PWD=your_password;

# For SQLite (default - uncomment to use):
DB_CONNECTION_STRING=sqlite:///applicants.db

