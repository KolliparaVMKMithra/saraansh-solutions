<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <system.webServer>
        <handlers>
            <add name="PythonHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
        </handlers>
        <httpPlatform processPath="D:\home\site\wwwroot\env\Scripts\waitress-serve.exe" 
                      arguments="--port=%HTTP_PLATFORM_PORT% app:app"
                      startupTimeLimit="60" 
                      requestTimeout="00:04:00">
            <environmentVariables>
                <environmentVariable name="PYTHONPATH" value="D:\home\site\wwwroot"/>
            </environmentVariables>
        </httpPlatform>
    </system.webServer>
</configuration>
